    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.2.3",
    "next": "^14.2.29",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.4"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.28",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
