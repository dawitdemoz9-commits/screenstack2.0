# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://screenstack:screenstack@localhost:5432/screenstack"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="change-this-to-a-strong-secret-in-production"
JWT_EXPIRY="8h"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Storage (S3-compatible — use MinIO for local dev) ───────────────────────
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="screenstack"
STORAGE_REGION="us-east-1"

# ─── Code Execution (Judge0 — mocked in dev) ─────────────────────────────────
# For production connect to a Judge0 instance or RapidAPI
JUDGE0_URL="http://localhost:2358"
JUDGE0_API_KEY=""
CODE_EXECUTION_MOCK="true"

# ─── Email (mocked in dev — logs to console) ─────────────────────────────────
EMAIL_FROM="noreply@screenstack.local"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
EMAIL_MOCK="true"
